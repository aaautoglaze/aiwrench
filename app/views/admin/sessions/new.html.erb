<div class="min-h-[60vh] flex items-center justify-center">
  <div class="w-full max-w-md">
    <div class="text-center mb-8">
      <div class="flex items-center justify-center gap-2 mb-4">
        <span class="text-2xl">🔩</span>
        <span class="text-xl font-extrabold tracking-tight">
          ai<span class="text-[#2563eb]">Wrench</span>
        </span>
      </div>
      <h1 class="text-2xl font-bold">Admin Login</h1>
    </div>

    <div class="bg-[#111118] border border-gray-800/50 rounded p-8">
      <% if flash[:alert] %>
        <div class="mb-6 p-3 bg-red-900/30 border border-red-500/30 rounded text-red-300 text-sm">
          <%= flash[:alert] %>
        </div>
      <% end %>

      <%= form_with url: admin_login_path, method: :post, class: "space-y-6" do |f| %>
        <div>
          <label for="email" class="block text-sm font-semibold text-gray-300 mb-2">Email</label>
          <input type="email" name="email" id="email" required
                 class="w-full px-4 py-3 bg-[#0a0a0f] border border-gray-700 rounded text-white placeholder-gray-500 focus:outline-none focus:border-[#2563eb] focus:ring-1 focus:ring-[#2563eb] transition"
                 placeholder="admin@aiwrench.com">
        </div>

        <div>
          <label for="password" class="block text-sm font-semibold text-gray-300 mb-2">Password</label>
          <input type="password" name="password" id="password" required
                 class="w-full px-4 py-3 bg-[#0a0a0f] border border-gray-700 rounded text-white placeholder-gray-500 focus:outline-none focus:border-[#2563eb] focus:ring-1 focus:ring-[#2563eb] transition"
                 placeholder="••••••••">
        </div>

        <button type="submit" class="w-full px-6 py-3 bg-[#2563eb] text-white font-bold rounded hover:bg-[#1d4ed8] transition cursor-pointer shadow-lg shadow-[#2563eb]/25">
          Log In
        </button>
      <% end %>
    </div>
  </div>
</div>

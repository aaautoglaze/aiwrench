<!DOCTYPE html>
<html lang="en">
  <head>
    <title>aiWrench Admin</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">

    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-[#0a0a0f] text-gray-100 font-['Inter',sans-serif] antialiased min-h-screen">
    <!-- Admin Nav -->
    <nav class="bg-[#111118] border-b border-gray-800/50">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between h-14">
          <div class="flex items-center gap-4">
            <a href="<%= admin_root_path %>" class="flex items-center gap-2">
              <span class="text-lg">🔩</span>
              <span class="font-bold tracking-tight">ai<span class="text-[#2563eb]">Wrench</span></span>
            </a>
            <span class="text-gray-600">|</span>
            <span class="text-sm text-gray-400 font-semibold">Admin</span>
          </div>
          <% if defined?(current_admin) && current_admin %>
            <div class="flex items-center gap-4">
              <span class="text-sm text-gray-400"><%= current_admin.email %></span>
              <%= button_to "Logout", admin_logout_path, method: :delete, class: "text-sm text-gray-400 hover:text-white transition" %>
            </div>
          <% end %>
        </div>
      </div>
    </nav>

    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <% if flash[:notice] %>
        <div class="mb-6 p-3 bg-green-900/30 border border-green-500/30 rounded text-green-300 text-sm">
          <%= flash[:notice] %>
        </div>
      <% end %>

      <% if flash[:alert] %>
        <div class="mb-6 p-3 bg-red-900/30 border border-red-500/30 rounded text-red-300 text-sm">
          <%= flash[:alert] %>
        </div>
      <% end %>

      <%= yield %>
    </main>
  </body>
</html>

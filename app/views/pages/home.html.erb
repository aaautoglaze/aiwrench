<!-- Contact / Lead Form Section -->
<section id="contact" class="py-24 relative">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12">
      <span class="text-[#2563eb] text-sm font-semibold tracking-wider uppercase">Let's Talk</span>
      <h2 class="mt-3 text-4xl sm:text-5xl font-extrabold tracking-tight">Get Started</h2>
      <p class="mt-4 text-gray-400">Tell us about your project and we'll get back to you within 1 business day.</p>
    </div>

    <% if flash[:notice] %>
      <div class="mb-8 p-4 bg-green-900/30 border border-green-500/30 rounded text-green-300 text-center font-semibold">
        <%= flash[:notice] %>
      </div>
    <% end %>

    <% if flash[:alert] %>
      <div class="mb-8 p-4 bg-red-900/30 border border-red-500/30 rounded text-red-300 text-center font-semibold">
        <%= flash[:alert] %>
      </div>
    <% end %>

    <div class="bg-[#111118] border border-gray-800/50 rounded p-8 sm:p-10">
      <%= form_with model: @lead, url: leads_path, class: "space-y-6" do |f| %>
        <!-- Honeypot -->
        <div class="absolute" style="left: -9999px; top: -9999px;">
          <label for="website">Website</label>
          <input type="text" name="website" id="website" tabindex="-1" autocomplete="off">
        </div>

        <div class="grid sm:grid-cols-2 gap-6">
          <div>
            <label for="lead_name" class="block text-sm font-semibold text-gray-300 mb-2">Name *</label>
            <%= f.text_field :name, class: "w-full px-4 py-3 bg-[#0a0a0f] border border-gray-700 rounded text-white placeholder-gray-500 focus:outline-none focus:border-[#2563eb] focus:ring-1 focus:ring-[#2563eb] transition", placeholder: "John Smith", required: true %>
          </div>
          <div>
            <label for="lead_company" class="block text-sm font-semibold text-gray-300 mb-2">Company</label>
            <%= f.text_field :company, class: "w-full px-4 py-3 bg-[#0a0a0f] border border-gray-700 rounded text-white placeholder-gray-500 focus:outline-none focus:border-[#2563eb] focus:ring-1 focus:ring-[#2563eb] transition", placeholder: "Acme Inc." %>
          </div>
        </div>

        <div class="grid sm:grid-cols-2 gap-6">
          <div>
            <label for="lead_email" class="block text-sm font-semibold text-gray-300 mb-2">Email *</label>
            <%= f.email_field :email, class: "w-full px-4 py-3 bg-[#0a0a0f] border border-gray-700 rounded text-white placeholder-gray-500 focus:outline-none focus:border-[#2563eb] focus:ring-1 focus:ring-[#2563eb] transition", placeholder: "john@acme.com", required: true %>
          </div>
          <div>
            <label for="lead_phone" class="block text-sm font-semibold text-gray-300 mb-2">Phone</label>
            <%= f.telephone_field :phone, class: "w-full px-4 py-3 bg-[#0a0a0f] border border-gray-700 rounded text-white placeholder-gray-500 focus:outline-none focus:border-[#2563eb] focus:ring-1 focus:ring-[#2563eb] transition", placeholder: "(555) 123-4567" %>
          </div>
        </div>

        <div class="grid sm:grid-cols-2 gap-6">
          <div>
            <label for="lead_industry" class="block text-sm font-semibold text-gray-300 mb-2">Industry</label>
            <%= f.select :industry, Lead::INDUSTRIES, { include_blank: "Select your industry" }, class: "w-full px-4 py-3 bg-[#0a0a0f] border border-gray-700 rounded text-white focus:outline-none focus:border-[#2563eb] focus:ring-1 focus:ring-[#2563eb] transition" %>
          </div>
          <div>
            <label for="lead_service_interest" class="block text-sm font-semibold text-gray-300 mb-2">Service Interested In</label>
            <%= f.select :service_interest, Lead::SERVICES, { include_blank: "Select a service" }, class: "w-full px-4 py-3 bg-[#0a0a0f] border border-gray-700 rounded text-white focus:outline-none focus:border-[#2563eb] focus:ring-1 focus:ring-[#2563eb] transition" %>
          </div>
        </div>

        <div>
          <label for="lead_message" class="block text-sm font-semibold text-gray-300 mb-2">Message</label>
          <%= f.text_area :message, rows: 5, class: "w-full px-4 py-3 bg-[#0a0a0f] border border-gray-700 rounded text-white placeholder-gray-500 focus:outline-none focus:border-[#2563eb] focus:ring-1 focus:ring-[#2563eb] transition resize-none", placeholder: "Tell us about your project..." %>
        </div>

        <% if ENV["HCAPTCHA_SITE_KEY"].present? %>
          <div class="flex justify-center">
            <div class="h-captcha" data-sitekey="<%= ENV['HCAPTCHA_SITE_KEY'] %>" data-theme="dark"></div>
            <script src="https://js.hcaptcha.com/1/api.js" async defer></script>
          </div>
        <% end %>

        <div>
          <%= f.submit "Send Message", class: "w-full px-8 py-4 bg-[#2563eb] text-white font-bold text-lg rounded hover:bg-[#1d4ed8] transition cursor-pointer shadow-lg shadow-[#2563eb]/25 hover:shadow-[#2563eb]/40" %>
        </div>
      <% end %>
    </div>
  </div>
</section>


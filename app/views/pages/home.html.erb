        <span class="text-lg font-extrabold tracking-tight">
          ai<span class="text-[#2563eb]">Wrench</span>
        </span>
      </div>
      <p class="text-gray-500 text-sm">&copy; <%= Date.current.year %> aiWrench. All rights reserved.</p>
